        {
          "name": "TC-SEC-AUTH-03 Token firmado con HS256 (algoritmo incorrecto)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function b64url(str) {",
                  "    return btoa(unescape(encodeURIComponent(str)))",
                  "        .replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,'');",
                  "}",
                  "var now = Math.floor(Date.now()/1000);",
                  "var header = b64url(JSON.stringify({alg:'HS256',typ:'JWT'}));",
                  "var payload = b64url(JSON.stringify({",
                  "    sub:'attacker', aud:'komands-api',",
                  "    scope:'komands:provision komands:query',",
                  "    iat: now, exp: now + 3600",
                  "}));",
                  "var sig = CryptoJS.HmacSHA256(header+'.'+payload,'hacked-secret')",
                  "    .toString(CryptoJS.enc.Base64)",
                  "    .replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,'');",
                  "pm.variables.set('hs256_token', header+'.'+payload+'.'+sig);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-SEC-AUTH-03: Token HS256 → 401 (RS256 requerido)', function() {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "pm.test('Servidor rechaza algoritmo simétrico HS256', function() {",
                  "    pm.expect(pm.response.code).to.equal(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{hs256_token}}" },
              { "key": "X-Source-System", "value": "SN" },
              { "key": "X-Correlation-ID", "value": "{{$guid}}" },
              { "key": "X-Source-System-ID", "value": "abc123def4567890abcdef0123456789" },
              { "key": "X-User-ID", "value": "sec-tester" },
              { "key": "X-User-Role", "value": "agent" },
              { "key": "X-User-Organization", "value": "ON-NET CHILE" }
            ],
            "url": {
              "raw": "{{base_url}}/api/Komands/v1/query-access/{{test_olt_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "Komands", "v1", "query-access", "{{test_olt_id}}"]
            },
            "description": "ESCENARIO: JWT firmado con HS256 (simétrico). El servidor debe exigir RS256 (asimétrico).\nRESULTADO ESPERADO: HTTP 401 — algoritmo no aceptado.\nReferencia: TC-SEC-001 del Plan QA."
          },
          "response": []
        },
        {
          "name": "TC-SEC-AUTH-04 Payload JWT manipulado (scope elevado)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var t = pm.collectionVariables.get('access_token') || '';",
                  "if (t.split('.').length === 3) {",
                  "    var parts = t.split('.');",
                  "    try {",
                  "        var raw = parts[1].replace(/-/g,'+').replace(/_/g,'/');",
                  "        while (raw.length % 4) raw += '=';",
                  "        var pl = JSON.parse(atob(raw));",
                  "        pl.scope = 'komands:admin komands:superuser';",
                  "        pl.sub = 'hacker';",
                  "        var newP = btoa(JSON.stringify(pl))",
                  "            .replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=/g,'');",
                  "        pm.variables.set('tampered_token', parts[0]+'.'+newP+'.'+parts[2]);",
                  "    } catch(e) {",
                  "        pm.variables.set('tampered_token','bad.tampered.token');",
                  "    }",
                  "} else {",
                  "    pm.variables.set('tampered_token','no.valid.token');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-SEC-AUTH-04: Payload manipulado → 401 (firma inválida)', function() {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "pm.test('Servidor detecta manipulación de payload JWT', function() {",
                  "    pm.expect(pm.response.code).to.equal(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tampered_token}}" },
              { "key": "X-Source-System", "value": "SN" },
              { "key": "X-Correlation-ID", "value": "{{$guid}}" },
              { "key": "X-Source-System-ID", "value": "abc123def4567890abcdef0123456789" },
              { "key": "X-User-ID", "value": "sec-tester" },
              { "key": "X-User-Role", "value": "agent" },
              { "key": "X-User-Organization", "value": "ON-NET CHILE" }
            ],
            "url": {
              "raw": "{{base_url}}/api/Komands/v1/query-access/{{test_olt_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "Komands", "v1", "query-access", "{{test_olt_id}}"]
            },
            "description": "ESCENARIO: Token válido con payload modificado (scope elevado a admin). La firma ya no coincide.\nRESULTADO ESPERADO: HTTP 401 — firma inválida.\nReferencia: TC-SEC-004 del Plan QA."
          },
          "response": []
        },

    {
      "name": "TC-SEC-RES — Headers de seguridad en respuesta",
      "item": [
        {
          "name": "TC-SEC-RES-01 Headers de seguridad HTTP en /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-SEC-RES-01: Health responde 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var headers = {};",
                  "pm.response.headers.each(function(h) { headers[h.key.toLowerCase()] = h.value; });",
                  "pm.test('[GAP-SEC] X-Content-Type-Options ausente (riesgo MIME-sniffing)', function() {",
                  "    var val = headers['x-content-type-options'];",
                  "    if (!val) { console.warn('GAP: Agregar header: X-Content-Type-Options: nosniff'); }",
                  "    else { console.log('X-Content-Type-Options:', val); }",
                  "    pm.expect(val).to.exist;",
                  "});",
                  "pm.test('[GAP-SEC] X-Frame-Options ausente (riesgo clickjacking)', function() {",
                  "    var val = headers['x-frame-options'];",
                  "    if (!val) { console.warn('GAP: Agregar header: X-Frame-Options: DENY'); }",
                  "    else { console.log('X-Frame-Options:', val); }",
                  "    pm.expect(val).to.exist;",
                  "});",
                  "pm.test('[GAP-SEC] Strict-Transport-Security ausente (HSTS no configurado)', function() {",
                  "    var val = headers['strict-transport-security'];",
                  "    if (!val) { console.warn('GAP: Agregar header: Strict-Transport-Security: max-age=31536000; includeSubDomains'); }",
                  "    else { console.log('Strict-Transport-Security:', val); }",
                  "    pm.expect(val).to.exist;",
                  "});",
                  "pm.test('Server header no expone versión del servidor', function() {",
                  "    var server = headers['server'] || '';",
                  "    console.log('Server header:', server || '(ausente)');",
                  "    var hasVersion = /[0-9]+\\.[0-9]+/.test(server);",
                  "    if (hasVersion) { console.warn('ADVERTENCIA: Server header expone versión:', server); }",
                  "    pm.expect(hasVersion).to.be.false;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "ESCENARIO: Verificar headers de seguridad HTTP en respuesta.\nRESULTADO ESPERADO: X-Content-Type-Options, X-Frame-Options, HSTS presentes."
          },
          "response": []
        },
        {
          "name": "TC-SEC-RES-02 Content-Type en respuesta de error",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-SEC-RES-02: Error de autenticación retorna Content-Type application/json', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "    var ct = pm.response.headers.get('Content-Type') || '';",
                  "    console.log('Content-Type en error ' + pm.response.code + ':', ct);",
                  "    pm.expect(ct).to.include('application/json');",
                  "});",
                  "pm.test('Cuerpo de error no expone stack trace ni rutas internas', function() {",
                  "    var body = pm.response.text();",
                  "    var exposesStack = body.toLowerCase().includes('traceback') || body.toLowerCase().includes('file \"/');",
                  "    if (exposesStack) { console.warn('ADVERTENCIA: Respuesta podría exponer stack trace'); }",
                  "    pm.expect(exposesStack).to.be.false;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [
              { "key": "X-Source-System", "value": "SN" },

{
  "info": {
    "name": "APIM PRE — VNO 03 Entel (Newman)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 — Obtener Token",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let cKey = pm.environment.get('consumerKey');",
              "let cPass = pm.environment.get('consumerSecret');",
              "let authorization = btoa(cKey + ':' + cPass);",
              "pm.environment.set('authorization', authorization);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Token obtenido correctamente', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var jsonData = JSON.parse(responseBody);",
              "pm.environment.set('Token', jsonData.access_token);",
              "console.log('Token OK — expira en ' + jsonData.expires_in + 's');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Basic {{authorization}}" }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "grant_type", "value": "client_credentials", "type": "text" }
          ]
        },
        "url": {
          "raw": "{{apimURL}}/token",
          "host": ["{{apimURL}}"],
          "path": ["token"]
        }
      }
    },
    {
      "name": "01 — DeviceModification Sincrónico",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 o 202', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 202]);",
              "});",
              "pm.test('Respuesta tiene campo result', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body).to.have.property('result');",
              "});",
              "pm.test('return_code presente', function () {",
              "  var body = pm.response.json();",
              "  pm.expect(body.result).to.have.property('u_return_code');",
              "});",
              "console.log('DeviceModification SYNC — return_code: ' + pm.response.json().result.u_return_code + ' — ' + pm.response.json().result.u_return_code_desc);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{Token}}", "type": "string" }] },
        "method": "POST",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "vnoId", "value": "{{idvno}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"u_id_vno\": \"{{idvno}}\",\n  \"u_access_id_vno\": \"{{accessId}}\",\n  \"u_serial_number\": \"{{serial}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{apimURL}}/fullFillment-deviceModification/v1/deviceModification",
          "host": ["{{apimURL}}"],
          "path": ["fullFillment-deviceModification", "v1", "deviceModification"]
        }
      }

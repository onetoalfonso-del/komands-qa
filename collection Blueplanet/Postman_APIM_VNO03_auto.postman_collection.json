        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"u_id_vno\":         \"{{idvno}}\",\n  \"u_access_id_vno\":  \"{{accessId}}\",\n  \"u_operation_type\": \"M\",\n  \"u_speed_plan\":     \"{{speedPlan}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{apimURL}}/fullFillment-modification/v1/registrationModification",
          "host": ["{{apimURL}}"],
          "path": ["fullFillment-modification", "v1", "registrationModification"]
        },
        "description": "Cambio de plan de velocidad sincrónico.\nu_operation_type: 'M' (Modificación)\nu_speed_plan: plan en formato 'bajada/subida' — ej: 940/940"
      }
    },
    {
      "name": "04 — Modification Asincrónica (SSAA)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200 o 202', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 202]);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('Respuesta tiene campo result', function () {",
              "    pm.expect(body).to.have.property('result');",
              "});",
              "",
              "// El campo result puede venir como string JSON en este endpoint",
              "const result = (typeof body.result === 'string') ? JSON.parse(body.result) : body.result;",
              "",
              "if (result) {",
              "    pm.test('result.u_return_code presente', function () {",
              "        pm.expect(result).to.have.property('u_return_code');",
              "    });",
              "    pm.test('result.u_return_code_desc presente', function () {",
              "        pm.expect(result).to.have.property('u_return_code_desc');",
              "    });",
              "    console.log('[ModSSAA ASYNC] rc=' + result.u_return_code + ' | ' + result.u_return_code_desc);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{Token}}", "type": "string" }]

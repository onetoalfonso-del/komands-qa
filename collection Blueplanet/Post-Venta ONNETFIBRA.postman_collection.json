  "item": [
    {
      "name": "01-feasibility",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"La factibilidad es positiva\", function () {\r",
              "  pm.expect(return_code).to.eql(\"0\");\r",
              "  });\r",
              "pm.test(\"El AddressID no está registrado\", function () {\r",
              "  pm.expect(return_code).to.eql(\"2\");\r",
              "  })\r",
              "pm.test(\"El Address ID no corresponde a un área de cobertura contratada\", function () {\r",
              "  pm.expect(return_code).to.eql(\"4\");\r",
              "  })\r",
              "pm.test(\"La dirección solicitada no tiene cobertura\", function () {\r",
              "  pm.expect(return_code).to.eql(\"10\");\r",
              "  })\r",
              "pm.test(\"La dirección no corresponde a un área de cobertura contratada\", function () {\r",
              "  pm.expect(return_code).to.eql(\"13\");\r",
              "  })\r",
              "pm.test(\"Dirección con cobertura, pero no hay facilidad disponible\", function () {\r",
              "  pm.expect(return_code).to.eql(\"14\");\r",
              "  })\r",
              "pm.test(\"Dirección sin cobertura de red (Caja verde)\", function () {\r",
              "  pm.expect(return_code).to.eql(\"15\");\r",
              "  })\r",
              "pm.test(\"Sin cobertura de red\", function () {\r",
              "  pm.expect(return_code).to.eql(\"16\");\r",
              "  })\r",
              "pm.test(\"Con disponibilidad de red (Caja verde)\", function () {\r",
              "  pm.expect(return_code).to.eql(\"18\");\r",
              "  })\r",
              "var template = `\r",
              "<style type=\"text/css\">\r",
              "    .tftable {font-size:14px;color:#333333;width:100%;border-width: 1px;border-color: #87ceeb;border-collapse: collapse;}\r",
              "    .tftable th {font-size:18px;background-color:#000000;color: #ffffff;border-width: 1px;padding: 8px;border-style: solid;border-color: #000000;text-align:left;}\r",
              "    .tftable tr {background-color:#2F4F4F;color: #ffffff;}\r",
              "    .tftable td {font-size:14px;border-width: 1px;padding: 8px;border-style: solid;border-color: #87ceeb;background-color:#2F4F4F;color: #ffffff;}\r",
              "    .tftable tr:hover {background-color:#e0ffff;color: #000000;} /* Color al pasar el ratón */\r",
              "</style>\r",
              "\r",
              "<table class=\"tftable\" border=\"1\">\r",
              "    <tr>\r",
              "        <th>Field Name</th>\r",
              "        <th>Value</th>\r",
              "    </tr>\r",
              "\r",
              "    <tr>\r",
              "        <td>u_return_code_desc</td>\r",
              "        <td>{{response.result.u_return_code_desc}}</td>\r",
              "    </tr>\r",
              "    <tr>\r",
              "        <td>u_available_bandwidth_assured_gpon</td>\r",
              "        <td>{{response.result.u_available_bandwidth_assured_gpon}}</td>\r",
              "    </tr>\r",
              "    <tr>\r",
              "        <td>u_available_bandwidth_fixed_gpon</td>\r",
              "        <td>{{response.result.u_available_bandwidth_fixed_gpon}}</td>\r",
              "    </tr>\r",
              "    <tr>\r",
              "        <td>u_available_bandwidth_assured_xgspon</td>\r",
              "        <td>{{response.result.u_available_bandwidth_assured_xgspon}}</td>\r",
              "    </tr>\r",
              "    <tr>\r",
              "        <td>u_available_bandwidth_fixed_xgspon</td>\r",
              "        <td>{{response.result.u_available_bandwidth_fixed_xgspon}}</td>\r",
              "    </tr>\r",
              "</table>\r",
              "`;\r",
              "\r",
              "function constructVisualizerPayload() {\r",
              "    var responseData = pm.response.json();\r",
              "    var visualizerData = {\r",
              "        result: {\r",
              "            u_return_code_desc: responseData.result.u_return_code_desc,\r",
              "            u_available_bandwidth_assured_gpon: responseData.result.u_available_bandwidth_assured_gpon,\r",
              "            u_available_bandwidth_fixed_gpon: responseData.result.u_available_bandwidth_fixed_gpon,\r",
              "            u_available_bandwidth_assured_xgspon: responseData.result.u_available_bandwidth_assured_xgspon,\r",
              "            u_available_bandwidth_fixed_xgspon: responseData.result.u_available_bandwidth_fixed_xgspon\r",
              "        }\r",
              "    };\r",
              "    return {response: visualizerData};\r",
              "}\r",
              "\r",
              "pm.visualizer.set(template, constructVisualizerPayload());"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },

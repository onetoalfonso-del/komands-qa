    {
      "name": "00-get Token Copy",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let cKey = pm.environment.get('consumerKey');\r",
              "let cPass = pm.environment.get('consumerSecret');\r",
              "let authorization = btoa(cKey + \":\" + cPass);\r",
              "pm.environment.set(\"authorization\", authorization);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = JSON.parse(responseBody); //Asigna a la variable jsonData el contenido del  response body \r",
              "\r",
              "pm.environment.set(\"Token\",jsonData.access_token) //extrae el token desde jsonData y lo asigna a la variable ambiental  token"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "protocolProfileBehavior": {
        "disabledSystemHeaders": {}
      },
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic {{authorization}}"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "client_credentials",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{apimURL}}/token",
          "host": [
            "{{apimURL}}"
          ],
          "path": [
            "token"
          ]
        }

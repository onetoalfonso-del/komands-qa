{
  "info": {
    "_postman_id": "9eb71a17-d8c9-4bed-ad9b-65706a19eec7",
    "name": "Komands — APIM PRE VNOs 02/03 Claro/Entel (Auto-Token)",
    "description": "Suite de integración contra APIM PRE-PROD — VNOs 02 (ClaroVTR) y 03 (Entel).\n\nPara activar o desactivar un VNO antes de correr, edita el environment:\n  vno02_enabled = true  →  ejecuta VNO 02\n  vno02_enabled = false →  salta todos los requests de VNO 02\n  vno03_enabled = true  →  ejecuta VNO 03\n  vno03_enabled = false →  salta todos los requests de VNO 03\n\nEl token OAuth2 se obtiene automáticamente por VNO con caché de sesión.\nEnvironment requerido: APIM PRE — VNOs 02+03 (Combined).postman_environment.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "56013580"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{Token}}", "type": "string" }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.response.code === 401) {",
          "    pm.test('AUTH FALLIDA (401) — token inválido o expirado', () => pm.expect.fail('HTTP 401'));",
          "}",
          "if (pm.response.code === 403) {",
          "    pm.test('ACCESO DENEGADO (403) — revisar permisos del consumer key', () => pm.expect.fail('HTTP 403'));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "VNO 02 — ClaroVTR",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ── VNO 02 — ClaroVTR: habilitar/deshabilitar y token ─────────────────",
              "const vno = '02';",
              "const enabled = pm.environment.get('vno02_enabled');",
              "if (enabled === 'false' || enabled === false) {",
              "    pm.collectionVariables.set('_skipVno', 'true');",
              "    console.log('[VNO 02] Deshabilitado — se saltarán todos los requests de esta carpeta');",
              "    pm.execution.skipRequest();",
              "    return;",
              "}",
              "pm.collectionVariables.set('_skipVno', 'false');",
              "pm.collectionVariables.set('idvno',     '02');",
              "pm.collectionVariables.set('accessId',  pm.environment.get('accessId_02'));",
              "pm.collectionVariables.set('serial',    pm.environment.get('serial_02'));",
              "pm.collectionVariables.set('speedPlan', pm.environment.get('speedPlan_02'));",
              "",
              "const apimURL = pm.environment.get('apimURL');",
              "const cKey    = pm.environment.get('consumerKey_02');",
              "const cSecret = pm.environment.get('consumerSecret_02');",
              "const expiresAt = pm.collectionVariables.get('_tokenExpiresAt_02');",
              "if (expiresAt && Date.now() < parseInt(expiresAt)) {",
              "    pm.collectionVariables.set('Token', pm.collectionVariables.get('_token_02'));",
              "    const s = Math.round((parseInt(expiresAt) - Date.now()) / 1000);",
              "    console.log('[Token VNO02] En caché — válido por ' + s + 's más');",
              "    return;",
              "}",
              "if (!cKey || !cSecret) {",
              "    console.error('[Token VNO02] ERROR: faltan consumerKey_02 o consumerSecret_02 en el environment');",
              "    return;",
              "}",
              "pm.sendRequest({",
              "    url: apimURL + '/token',",
              "    method: 'POST',",
              "    header: { 'Authorization': 'Basic ' + btoa(cKey + ':' + cSecret), 'Content-Type': 'application/x-www-form-urlencoded' },",
              "    body: { mode: 'urlencoded', urlencoded: [{ key: 'grant_type', value: 'client_credentials' }] }",
              "}, function(err, res) {",
              "    if (err) { console.error('[Token VNO02] Error de red: ' + err); return; }",
              "    if (res.code !== 200) { console.error('[Token VNO02] HTTP ' + res.code + ': ' + res.text()); return; }",
              "    const j = res.json();",
              "    const ttl = j.expires_in || 3600;",
              "    pm.collectionVariables.set('Token',              j.access_token);",
              "    pm.collectionVariables.set('_token_02',          j.access_token);",
              "    pm.collectionVariables.set('_tokenExpiresAt_02', String(Date.now() + (ttl - 60) * 1000));",
              "    console.log('[Token VNO02] Nuevo token obtenido — expira en ' + ttl + 's');",
              "});"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "01 — DeviceModification Sincrónico",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": [
                "if (pm.collectionVariables.get('_skipVno') === 'true') { pm.execution.skipRequest(); return; }"
              ]}
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('HTTP 200 o 202', function () { pm.expect(pm.response.code).to.be.oneOf([200, 202]); });",
                "const body = pm.response.json();",
                "console.log('[DevMod SYNC VNO02] RAW BODY: ' + JSON.stringify(body));",
                "pm.test('Respuesta tiene campo result', function () { pm.expect(body).to.have.property('result'); });",
                "if (body && body.result) {",
                "    const r = (typeof body.result === 'string') ? JSON.parse(body.result) : body.result;",
                "    pm.test('result.u_return_code presente', function () { pm.expect(r).to.have.property('u_return_code'); });",
                "    pm.test('result.u_return_code_desc presente', function () { pm.expect(r).to.have.property('u_return_code_desc'); });",
                "    const rc = r.u_return_code || '(vacío)'; const desc = r.u_return_code_desc || '(sin desc)';",
                "    console.log('[DevMod SYNC VNO02] rc=' + rc + ' | ' + desc + ' | access=' + (r.u_access_id_vno||'?') + ' | serial=' + (r.u_serial_number||'?') + (r.sys_id ? ' | sys_id=' + r.sys_id : ''));",
                "} else { console.warn('[DevMod SYNC VNO02] body.result ausente'); }"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "vnoId", "value": "{{idvno}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"u_id_vno\":        \"{{idvno}}\",\n  \"u_access_id_vno\": \"{{accessId}}\",\n  \"u_serial_number\": \"{{serial}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{apimURL}}/fullFillment-deviceModification/v1/deviceModification",
              "host": ["{{apimURL}}"],
              "path": ["fullFillment-deviceModification", "v1", "deviceModification"]
            }
          },
          "response": []
        },

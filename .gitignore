# Entorno virtual
.venv/

# Cache Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Pytest / cobertura
.pytest_cache/
.coverage
htmlcov/
reports/

# IDEs
.vscode/
.idea/
*.swp

# Sistema
.DS_Store
Thumbs.db

# Documentos de planificación (no van al repo)
*.xlsx
*.xls
~$*

# Documentos Word — van en SharePoint, no en git
*.docx
*.doc

# Archivos de ambiente Postman con credenciales (solo locales, nunca al repo)
collection Blueplanet/*.postman_environment.json
collection Blueplanet/*.postman_environment
collection Blueplanet/*.environment.json
collection Kommand/newman-environment-dev.json

# Reportes HTML generados por pytest
reporte*.html
reporte-ci.html

# Allure — resultados e historial (se publican en GitHub Pages)
allure-results/
allure-report/
allure-history/

# Logs de ejecución
logs/

# Configuración local de Claude Code
.claude/

# Metadatos Windows
desktop.ini

# Screenshots y HTML generados por crawling del portal
*.png
*_page.html
komands_portal_doc.html
flujos_screenshot.png
login_screenshot.png

# Scripts de inspección/crawling (utilitarios locales)
inspect_*.py
komands_crawler.py

# Archivos temporales
Prueba Demo .txt

# Config generado durante Docker build (contiene credenciales, nunca al repo)
apim-config.json

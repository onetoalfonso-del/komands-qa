    {
      "name": "RetrieveAccess ( TCH)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"resultado esperado\", function () {\r",
              "     pm.expect(pm.response.responseTime).to.be.below(200);\r",
              "});\r",
              " \r",
              "pm.test(\"resultado esperado\", function () {\r",
              "     pm.response.to.be.below(200);\r",
              "});\r",
              " \r",
              "pm.test(\"resultado esperado\", ()=> {\r",
              "     pm.response.to.be.status(200);\r",
              "});\r",
              " \r",
              "pm.test(\"analizar json\", function () {\r",
              "     pm.expect(pm.response.json()).to.be.an('object');\r",
              "     pm.expect(pm.response.json()).to.have.property('u_return_code');\r",
              "     pm.expect(pm.response.json()).to.have.property('u_id_vno');\r",
              "     pm.expect(pm.response.json()).to.have.property('u_access_id_vno');\r",
              "     pm.expect(pm.response.json()).to.have.property('u_flag_scope');\r",
              "     pm.expect(pm.response.json()).to.have.property('u_isp_return_code');\r",
              "     pm.expect(pm.response.json()).to.have.property('u_isp_access_status');\r",
              "     pm.expect(pm.response.json()).to.have.property('u_isp_olt_ip');\r",
              "     pm.expect(pm.response.json()).to.have.property('u_isp_model');\r",
              "     pm.expect(pm.response.json()).to.have.property('u_isp_gestion_service_status');\r",
              "     pm.expect(pm.response.json()).to.have.property('u_osp_RFS_LAST_MILE');\r",
              "     pm.expect(pm.response.json()).to.have.property('u_osp_completeInformations');\r",
              "     pm.expect(pm.response.json()).to.have.property('u_osp_supplementaryInformation');\r",
              "});\r",
              " \r",
              "console.log(pm.response.headers.get('date'));\r",
              " \r",
              "pm.response.json();"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
